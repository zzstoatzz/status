 /** Update the handle for a DID if it exists in _repos. */
 export declare function updateRepoHandle(did: string, handle: string): Promise<void>;
 export declare function getRepoRev(did: string): Promise<string | null>;
+/**
+ * Advance the stored rev for a repo without touching status or backfilled_at.
+ *
+ * Called from the firehose insert path after a commit has been successfully
+ * indexed. Keeps `_repos.rev` current so that future backfills via
+ * `getRepo?since=<rev>` only fetch the small diff since the last seen commit
+ * rather than walking the whole repo history. Without this, `_repos.rev`
+ * would only ever advance during a full `backfillRepo` run, drifting stale
+ * over time and forcing on-login backfills to fetch a large diff (or worse,
+ * miss commits entirely if the firehose ever drops events).
+ *
+ * No-ops if the rev is empty or the row doesn't exist (we don't insert here;
+ * that's `setRepoStatus`'s job during initial discovery). The
+ * `rev < $1` guard prevents regression if events arrive out of order.
+ */
+export declare function updateRepoRev(did: string, rev: string): Promise<void>;
 export declare function getRepoRetryInfo(did: string): Promise<{
     retryCount: number;
     retryAfter: number;
